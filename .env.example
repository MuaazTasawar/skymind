# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=skymind
POSTGRES_PASSWORD=skymind_secret
POSTGRES_DB=skymind

# ─── Go Gateway ───────────────────────────────────────────────
GATEWAY_PORT=8080
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRY_HOURS=24

# ─── Python Planner (gRPC) ────────────────────────────────────
PLANNER_GRPC_HOST=localhost
PLANNER_GRPC_PORT=50051

# ─── SITL ─────────────────────────────────────────────────────
SITL_BASE_PORT=5760
SITL_DRONE_COUNT=5

# ─── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws